---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <main class="min-h-screen bg-gradient-to-br py-12 px-4">
    <div class="max-w-2xl mx-auto">
      <header class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-ctp-text mb-4">
          Contact Me
        </h1>
        <p class="text-lg text-ctp-subtext0">
          I'm excited to hear from you! Whether you have a question, want to
          discuss a project, or just want to say hello, feel free to reach out
          using the form below. I'll get back to you as soon as possible.
        </p>
      </header>

      <section class="bg-ctp-base rounded-2xl shadow-xl p-8 md:p-10">
        <form
          action="https://formspree.io/f/mrbknyvw"
          method="POST"
          class="space-y-6"
        >
          <div class="space-y-2">
            <label
              for="name"
              class="block text-sm font-medium text-ctp-subtext2"
            >
              Name *
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border border-ctp-surface2 rounded-lg bg-ctp-mantle text-ctp-text placeholder-ctp-subtext2 focus:ring-2 focus:ring-ctp-blue focus:border-transparent transition duration-200"
              placeholder="Your full name"
            />
          </div>

          <div class="space-y-2">
            <label
              for="email"
              class="block text-sm font-medium text-ctp-subtext2"
            >
              Email *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-ctp-surface2 rounded-lg bg-ctp-mantle text-ctp-text placeholder-ctp-subtext2 focus:ring-2 focus:ring-ctp-blue focus:border-transparent transition duration-200"
              placeholder="you@email.com"
            />
          </div>

          <div class="space-y-2">
            <label
              for="message"
              class="block text-sm font-medium text-ctp-subtext2"
            >
              Message *
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 border border-ctp-surface2 rounded-lg bg-ctp-mantle text-ctp-text placeholder-ctp-subtext2 focus:ring-2 focus:ring-ctp-blue focus:border-transparent transition duration-200"
              placeholder="Tell me about your project..."></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-gradient-to-r from-ctp-blue to-ctp-sky hover:from-ctp-sky hover:to-ctp-lavender hover:cursor-pointer text-ctp-mantle font-semibold py-4 px-6 rounded-lg shadow-lg hover:shadow-xl transform hover:scale-[1.05] focus:ring-4 focus:ring-ctp-blue focus:ring-opacity-50 transition duration-200"
          >
            Send Message
          </button>
        </form>
      </section>
    </div>
  </main>
</BaseLayout>
