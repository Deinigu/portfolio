---
import { Image } from "astro:assets";
import imgPath from "../assets/about.png";
import BaseLayout from "../layouts/BaseLayout.astro";
import Skill from "../components/Skill.astro";
---

<BaseLayout>
  <header class="text-center mb-12">
    <h1 class="text-4xl md:text-5xl font-bold text-ctp-text mb-4">About Me</h1>
  </header>
  <Image
    src={imgPath}
    alt="Profile picture"
    loading="lazy"
    decoding="async"
    class="max-w-s mx-auto mb-6 rounded-lg shadow-lg border-4 border-ctp-overlay1"
  />
  <Skill />
</BaseLayout>
