---
import { Image } from "astro:assets";
import imgPath from "../assets/about.png";
import BaseLayout from "../layouts/BaseLayout.astro";
import Skills from "../components/Skills.astro";
---

<BaseLayout>
  <header class="text-center mb-8 md:mb-12">
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-ctp-text mb-4">
      About Me
    </h1>
  </header>

  <div
    class="flex flex-col lg:flex-row items-center gap-6 md:gap-8 mb-8 md:mb-12"
  >
    <div
      class="flex flex-col w-full lg:max-w-2xl items-center text-ctp-text order-2 lg:order-1"
    >
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 text-center">
        Diego López Reduello
      </h2>

      <div
        class="w-full max-w-sm sm:max-w-md md:max-w-lg lg:max-w-3xl mx-auto mb-4 md:mb-6"
      >
        <div
          class="bg-ctp-surface0 rounded-full h-2 md:h-3 overflow-hidden shadow-inner"
        >
          <div
            class="bg-gradient-to-r from-ctp-blue to-ctp-mauve h-full rounded-full transition-all duration-2000 ease-out animate-pulse"
            style="width: 100%; animation: loadBar 1s ease-in-out forwards;"
          >
          </div>
        </div>
      </div>

      <p
        class="text-sm sm:text-base lg:text-lg mb-4 text-center md:text-left px-4 md:px-0"
      >
        Hi! I'm Diego, a passionate data scientist with a focus on creating
        innovative and efficient solutions. I've been crafting solutions since I
        started programming Lego Robots when I was 13 years old. My journey has
        taken me through various fields, including web development, data
        science, game development, and more. I love exploring new technologies
        and finding creative ways to apply them to real-world problems.
      </p>
      <a
        href="/contact"
        class="mt-4 inline-block bg-ctp-blue hover:bg-ctp-mauve hover:scale-110 focus:scale-95 text-ctp-crust font-semibold py-2 px-4 rounded-full transition ease-in-out transform"
      >
        Get in Touch
      </a>
    </div>

    <div class="w-full sm:w-auto flex justify-center order-1 lg:order-2">
      <div
        class="relative group hover:shadow-2xl transition-shadow duration-300 ease-in-out"
      >
        <Image
          src={imgPath}
          alt="Profile picture of Diego López Reduello"
          loading="lazy"
          decoding="async"
          class="w-64 sm:w-80 md:w-96 lg:max-w-2xl rounded-lg shadow-xl border-2 md:border-4 border-ctp-overlay1 transition-transform duration-300 hover:scale-105 group-hover:shadow-2xl"
        />
      </div>
    </div>
  </div>

  <Skills />

  <style>
    @keyframes loadBar {
      0% {
        width: 0%;
      }
      100% {
        width: 100%;
      }
    }
  </style>
</BaseLayout>
