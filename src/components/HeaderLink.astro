---
const { href = "/", class: className = "", ...props } = Astro.props;

const currentPath = Astro.url.pathname;

// Normaliza eliminando slash final (si tiene) para comparar bien
const normalizePath = (path: string) => path.replace(/\/$/, "");

const normalizedCurrent = normalizePath(currentPath);
const hrefString = href?.toString() || "/";
const normalizedHref = normalizePath(hrefString);

const isRootPath = normalizedHref === "/portfolio";
const isPostsBase = normalizedHref === "/portfolio/posts";

const isActive = isRootPath
  ? normalizedCurrent === normalizedHref
  : isPostsBase
    ? normalizedCurrent.startsWith(normalizedHref)
    : normalizedCurrent === normalizedHref;

---

<a
  href={href}
  class={`${className} bg-ctp-surface1 text-ctp-text hover:bg-ctp-overlay2 hover:text-ctp-base m-1.5 flex rounded-3xl p-3 transition-all duration-100 hover:scale-110 active:scale-95 ease-in ${
    isActive ? "active" : ""
  }`}
  {...props}
>
  <slot />
</a>

<style>
  a {
    display: inline-block;
    text-decoration: none;
  }

  a.active {
    background: var(--color-ctp-blue);
    color: var(--color-ctp-base);
  }
</style>
