---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"a">;

const { href = "/", class: className, ...props } = Astro.props;

// Base URL sin barra final (ej: "/portfolio")
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Ruta final corregida
const finalHref = `${base}${href}`;

// Comparación para resaltar link activo
const currentPath = Astro.url.pathname;
const isActive =
  currentPath === finalHref ||
  (href !== "/" && currentPath.startsWith(finalHref + "/"));
---

<a href={finalHref} class:list={[className, { active: isActive }]} {...props}>
  <slot />
</a>

<style>
  a {
    display: inline-block;
    text-decoration: none;
    padding: 0.25rem 0.5rem;
  }

  a.active {
    font-weight: bold;
    text-decoration: underline;
  }
</style>
