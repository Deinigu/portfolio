---
// src/components/Skill.astro
import type { Skill } from "../consts";

import { skills } from "../consts";
---

<section id="skills" class="py-12 px-16 max-w-6xl mx-auto">
  <h2 class="text-3xl font-bold text-center mb-10">Skills</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
    {
      skills.map((skill) => (
        <div class="flex flex-col items-center text-center">
          <div class="w-20 h-20 mb-4 bg-ctp-base rounded-full shadow-md flex items-center justify-center hover:rotate-180 transition-transform duration-500">
            <img
              src={skill.imageSrc}
              alt={skill.title}
              class="w-12 h-12 object-contain"
            />
          </div>
          <p class="text-sm font-medium">{skill.title}</p>
        </div>
      ))
    }
  </div>
</section>
