---
import HeaderLink from "./HeaderLink.astro";
import Logo from "./Logo.astro";
---

<header class="bg-ctp-surface2 sticky top-0 z-50 shadow-md">
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8"
  >
    <!-- Left side: Logo -->
    <div class="items-left space-x-1 sm:space-x-2">
      <Logo href="/portfolio/" />
    </div>
    <!-- Center: Navigation links -->
    <div class="items-center space-x-1 sm:space-x-2">
      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        class="hover:bg-ctp-overlay2 focus:bg-ctp-surface1 hover:text-ctp-base flex items-center justify-center rounded-3xl p-3 transition-all duration-100 active:scale-95 lg:hidden ease-in"
      >
        <span class="hamburguer-icon">
          <span class="hamburguer-icon flex flex-col"></span>
          <span
            class="mb-1 block h-0.5 w-6 bg-current transition-transform duration-100"
          ></span>
          <span
            class="block h-0.5 w-6 bg-current transition-transform duration-100"
          ></span>
          <span
            class="mt-1 block h-0.5 w-6 bg-current transition-transform duration-100"
          ></span>
        </span>
      </button>
    </div>
    <!-- Desktop navigation -->
    <div
      class="hidden items-center space-x-1 lg:flex lg:flex-1 lg:justify-center xl:space-x-2"
    >
      <HeaderLink href="/portfolio/">Home</HeaderLink>
      <HeaderLink href="/portfolio/about/">About</HeaderLink>
      <HeaderLink href="/portfolio/projects/">Projects</HeaderLink>
      <HeaderLink href="/portfolio/games/">Games</HeaderLink>
      <HeaderLink href="/portfolio/music/">Music</HeaderLink>
      <HeaderLink href="/portfolio/contact/">Contact</HeaderLink>
    </div>
    <!-- Right side: Theme toggle-->
    <div class="flex flex-col items-right space-x-1 sm:space-x-1">
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="rounded-full w-10 h-10 bg-ctp-surface1 text-ctp-text hover:bg-ctp-overlay2 focus:bg-ctpsurface1 hover:text-ctp-base transition-all duration-100 hover:scale-110 hover:cursor-pointer active:scale-95"
      >
        <span class="icon-moon" aria-hidden="true">🌙</span>
        <span class="icon-sun hidden" aria-hidden="true">☀️</span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="max-h-0 items-center justify-center overflow-hidden transition-all duration-300 ease-in-out lg:hidden"
    aria-hidden="true"
  >
    <div
      class="bg-ctp-surface2 flex flex-col space-y-2 pb-2 align-middle shadow-md"
    >
      <HeaderLink href="/portfolio/" class="block py-2 text-center"
        >Home</HeaderLink
      >
      <HeaderLink href="/portfolio/about/" class="block py-2 text-center"
        >About</HeaderLink
      >
      <HeaderLink href="/portfolio/projects/" class="block py-2 text-center"
        >Projects</HeaderLink
      >
      <HeaderLink href="/portfolio/games/" class="block py-2 text-center"
        >Games</HeaderLink
      >
      <HeaderLink href="/portfolio/music/" class="block py-2 text-center"
        >Music</HeaderLink
      >
      <HeaderLink href="/portfolio/contact/" class="block py-2 text-center"
        >Contact</HeaderLink
      >
    </div>
  </div>
</header>

<style>
  .mobile-menu-open {
    max-height: 30rem;
  }
</style>

<script is:inline>
  // Theme toggle functionality
  const toggleTheme = document.getElementById("theme-toggle");
  const moon = toggleTheme.querySelector(".icon-moon");
  const sun = toggleTheme.querySelector(".icon-sun");

  const updateThemeIcon = (isDark) => {
    moon.style.display = isDark ? "none" : "inline";
    sun.style.display = isDark ? "inline" : "none";
  };

  const isDark = document.documentElement.classList.contains("dark");
  updateThemeIcon(isDark);

  toggleTheme.addEventListener("click", () => {
    const dark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", dark ? "dark" : "light");
    updateThemeIcon(dark);
  });

  // Mobile menu functionality
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const hamburgerIcon = menuToggle.querySelector(".hamburger-icon");

  let isMenuOpen = false;

  const toggleMobileMenu = () => {
    isMenuOpen = !isMenuOpen;

    // Update ARIA attributes
    menuToggle.setAttribute("aria-expanded", isMenuOpen.toString());
    mobileMenu.setAttribute("aria-hidden", (!isMenuOpen).toString());

    // Toggle menu visibility
    if (isMenuOpen) {
      mobileMenu.classList.add("mobile-menu-open");
      hamburgerIcon.classList.add("hamburger-open");
    } else {
      mobileMenu.classList.remove("mobile-menu-open");
      hamburgerIcon.classList.remove("hamburger-open");
    }
  };

  menuToggle.addEventListener("click", toggleMobileMenu);

  // Close mobile menu when clicking on a link (for single-page apps)
  const mobileLinks = mobileMenu.querySelectorAll("a");
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isMenuOpen) {
        toggleMobileMenu();
      }
    });
  });

  // Close mobile menu when window is resized to desktop size
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 1024 && isMenuOpen) {
      toggleMobileMenu();
    }
  });
</script>
