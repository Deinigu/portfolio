---
// Importaciones necesarias
import {
  getCollection,
  type CollectionKey,
  type InferEntrySchema,
  type RenderedContent,
} from "astro:content";
import Card from "./Card.astro";

// Lista de todas las colecciones que quieres incluir
const collections: CollectionKey[] = ["music", "games", "projects"]; // modifica esto con los nombres reales

// Obtener todas las entradas de todas las colecciones
const entries = await Promise.all(
  collections.map((collection) =>
    getCollection(collection).then((posts) =>
      posts.map((post) => ({
        ...post,
        collection,
      }))
    )
  )
);

const { limit } = Astro.props;

// Unir todas las entradas en una sola lista
const allPosts = entries.flat();

// Ordenar por fecha de publicación descendente (si existe pubDate)
const sortedPosts = allPosts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate || 0).getTime();
  const dateB = new Date(b.data.pubDate || 0).getTime();
  return dateB - dateA;
});

// Seleccionar solo las tres primeras
const selectedPosts = sortedPosts.slice(0, limit);
---

<section class="px-4 md:px-8 py-10">
  <h2 class="text-3xl md:text-4xl font-bold mb-6 text-left text-ctp-text">
    Recent Posts
  </h2>
  <div
    class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
  >
    {
      selectedPosts.map((post) => (
        <Card
          post={{
            ...post,
            data: {
              ...post.data,
              pubDate: post.data.pubDate?.toISOString().split("T")[0] || "",
              heroImage:
                typeof post.data.heroImage === "string"
                  ? post.data.heroImage
                  : post.data.heroImage?.src || "",
              tags: Array.isArray(post.data.tags) ? post.data.tags : [],
              collection: post.collection || "",
            },
          }}
          collection={post.collection}
          putCollectionTag={true}
        />
      ))
    }
  </div>
</section>
